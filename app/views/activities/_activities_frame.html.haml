.flex.flex-col.gap-4.justify-between.items-start.mb-10
  %div
    %span Qu'avez vous fait le...
    .flex.flex-col.lg:flex-row.lg:gap-4.lg:items-end
      %h1= l(@date, locale: :fr, format: :long)
      %h2= "de #{@activity.started_at.hour}h à #{@activity.ended_at.hour}h"

  .flex.flex-col
    .flex.justify-between.border-3.items-center
      = link_to activities_path(date: @activity.started_at.to_date - 1.week), class: "tooltip py-4!" do 
        = lucide_icon "chevrons-left"
        %span.tooltiptext Semaine précédente
      = link_to activities_path(date: @activity.started_at.to_date - 1.day), class: "tooltip py-4!" do 
        = lucide_icon "chevron-left"
        %span.tooltiptext Jour précédent
      = link_to activities_path, class: "tooltip py-4!" do 
        = lucide_icon "arrow-down"
        %span.tooltiptext Aujourd'hui
      = link_to activities_path(date: @activity.started_at.to_date + 1.day), class: "tooltip py-4! #{'disabled' if @activity.started_at.to_date + 1.day > Date.current}" do 
        = lucide_icon "chevron-right"
        %span.tooltiptext Jour suivant
      = link_to activities_path(date: @activity.started_at.to_date + 1.week), class: "tooltip py-4! #{'disabled' if @activity.started_at.to_date + 1.week > Date.current}" do 
        = lucide_icon "chevrons-right"
        %span.tooltiptext Semaine suivante

.space-y-6
  .grid.grid-cols-2.gap-4.text-lg.max-w-254
    - @categories.each do |category|
      = form_for :activity, url: activities_path, method: :post do |form|
        = form.hidden_field :id, value: @activity&.id
        = form.hidden_field :activity_category_id, value: category.id
        = form.hidden_field :started_at, value: @activity.started_at
        = form.submit category.label, class: "size-full p-6! hover:bg-(--cat-hover)!", style: "background-color: #{category.color}; color: #{contrasted_text_color(category.color)}; border: 5px solid #{darken_color(category.color)}; --cat-hover: #{darken_color(category.color)}"

  .title
    %h2.mt-10.flex.justify-between Activités de la journée
    %span= @feed.remaining_activities_count(date: @date) > 0 ? "#{@feed.remaining_activities_count(date: @date)} activité(s) à renseigner" : "Toutes les activités du jour ont été renseignées"

  .md:columns-2.gap-2
    - sleep_category = @categories.find(&:protected?)
    - @feed.slots.chunk(&:night).each do |is_night, slots|
      - if is_night
        %div.relative.group.break-inside-avoid
          %div{class: "absolute -inset-2 border-2 border-dashed border-night opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity shadow-lg z-10"}
          %div{class: "absolute top-0 left-1/2 -translate-x-1/2 -translate-y-2/3 opacity-0 group-hover:opacity-100 transition-opacity z-20 whitespace-nowrap"}
            = button_to 'Marquer la nuit en "Sommeil"', mark_night_as_sleep_path(date: @date), class: "text-xs px-2 py-0.5 bg-night text-white border border-white/40 cursor-pointer rounded"
          - slots.each do |slot|
            .flex.gap-6.justify-between.p-4.items-center.py-2{class: "#{"text-text/50" unless slot.filled?} #{"bg-primary text-text!" if slot.hour == @activity.started_at.hour}", style: (slot.hour == @activity.started_at.hour ? nil : "background-color: var(--color-night); opacity: 0.9; color: white;")}
              .font-bold.text-nowrap.flex.gap-2
                %span= "#{slot.hour} h"
                = lucide_icon :moon
              .flex.justify-between.items-center.text-xl{class: ("italic" unless slot.filled?)}
                %span= slot.label
              = link_to activities_path(datetime: DateTime.new(@date.year, @date.month, @date.day, slot.hour), activity_id: slot.activity&.id) do
                = lucide_icon :edit
      - else
        - slots.each do |slot|
          - slot_color = slot.filled? && slot.hour != @activity.started_at.hour ? slot.activity.category.color : nil
          .flex.gap-6.justify-between.p-4.items-center.py-2.break-inside-avoid{class: "#{"text-text/50" unless slot.filled?} #{"bg-primary text-text!" if slot.hour == @activity.started_at.hour}", style: [("background-color: #{slot_color}" if slot_color), ("color: #{contrasted_text_color(slot_color)}" if slot_color)].compact.join("; ")}
            .font-bold.text-nowrap.flex.gap-2
              %span= "#{slot.hour} h"
              = lucide_icon :sun
            .flex.justify-between.items-center.text-xl{class: ("italic" unless slot.filled?)}
              %span= slot.label
            = link_to activities_path(datetime: DateTime.new(@date.year, @date.month, @date.day, slot.hour), activity_id: slot.activity&.id) do
              = lucide_icon :edit