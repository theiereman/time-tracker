-# locals: (link:)

%dialog#share-modal.border-3.border-text.p-6.max-w-md.w-full.m-auto.bg-background{ class: "backdrop:bg-black/50", data: { controller: "modal element-removal", action: "close->element-removal#remove" } }
  .flex.items-center.justify-between.mb-4
    %p.font-extrabold.uppercase.text-lg= t(".title")
    %button{ type: "button", aria: { label: t(".close") }, data: { action: "modal#close" }, class: "p-0! hover:bg-transparent! hover:text-text!" }
      = lucide_icon "x", class: "size-6"

  .flex.gap-2.mb-4{ data: { controller: "clipboard" } }
    %input.flex-1{ type: "text", value: public_statistics_url(token: link.token), readonly: true, data: { clipboard_target: "source" } }
    %button{ type: "button", data: { action: "clipboard#copy", clipboard_target: "button", clipboard_copied_label: t(".copied") } }= t(".copy")

  = button_to t(".regenerate"), user_profile_link_path, method: :patch, class: "p-0! normal-case! font-normal! text-sm underline hover:bg-transparent! hover:text-text!", data: { turbo_confirm: t(".regenerate_confirm") }
