= content_for :title, t(".title")

.flex.flex-col.mb-12
  %h1= t(".title")
  - current_hour = DateTime.current.hour
  - current_minutes = DateTime.current.minute
  %span= t(".next_day_available", hours: 23 - current_hour, minutes: 60 - current_minutes, time: l(DateTime.current, format: :time_of_day))

.flex.gap-2.w-full.justify-between.items-center
  = link_to calendar_path(date: @date - 1.month) do
    = lucide_icon "arrow-left"
  = l(@date, format: "%B %Y")
  = link_to calendar_path(date: @date + 1.month) do
    = lucide_icon "arrow-right"

.max-w-xl.mx-auto{data: {"turbo-prefetch": "false", controller: "calendar-date-hover tooltip"}}
  .grid.grid-cols-7.gap-1.mt-6{data: {action: "mouseleave->calendar-date-hover#reset"}}
    - t(".weekdays").each do |weekday|
      %p.font-bold.opacity-50= weekday
    - @calendar.days.each do |day|
      %div{id: day.date.day, data: {"calendar-date-hover-target": "day", action: "mouseover->calendar-date-hover#highlight"}}
        = render "day", day: day

  %h2.mt-12.mb-2= t(".detailed_view_title")
  .flex.flex-col.w-full{class: "min-h-[600px]"}
    - activities = User::Progress.for_the_month(Current.user, @calendar.date)
    - @calendar.days.each do |day|
      .flex.h-5.items-center.text-sm.transition-all.overflow-hidden{id: day.date.day, data: {"calendar-date-hover-target": "line"}, class: "first:[&_#activities]:border-t last:[&_#activities]:border-b"}
        .w-8.font-semibold= day.date.day
        #activities.flex.flex-1.justify-stretch.border-x.h-full
          - activities.slots_for(day.date).each do |starts_at, activity|
            .w-full.tooltip{style: "background-color: #{activity&.category&.color}", data: {action: "mouseover->tooltip#show mouseout->tooltip#hide"}}
              - if activity
                %span.tooltiptext= "#{activity.category.label} #{t("common.from")} #{format_time(activity.started_at)} #{t("common.to")} #{format_time(activity.ended_at)}"

        .w-12.text-end.font-thin= number_to_percentage(day.percentage_done, precision: 0)
