= content_for :title, t(".title")

.sticky.flex.items-center.justify-between.mb-12
  %h1= t(".title")
  - if @shareable
    = button_to user_profile_link_path, class: "flex gap-2 items-center" do
      = lucide_icon "share-2", class: "size-4"
      = t(".share")

%h2= t(".activities_per_category")
.my-6= column_chart @count_per_category, legend: :bottom, library: { grouped: false, scales: { x: { ticks: { display: false } } }, interaction: { mode: "nearest", intersect: true } }

.overflow-x-auto.mb-12
  %table.w-full.text-sm
    %thead
      %tr.border-b.border-gray-200.text-left.text-gray-500
        %th.py-2.pr-4.font-medium= t(".table.category")
        %th.py-2.pr-4.font-medium.text-right= t(".table.hours")
        %th.py-2.font-medium.text-right= t(".table.percentage")
    %tbody
      - @top_categories.each do |row|
        %tr.border-b.border-gray-100
          %td.py-2.pr-4
            .flex.items-center.gap-2
              %span.inline-block.w-3.h-3.rounded-sm.shrink-0{ style: "background-color: #{row[:color]}" }
              = row[:label]
          %td.py-2.pr-4.text-right= row[:count]
          %td.py-2.text-right= "#{row[:percentage]}%"

%h2= t(".activities_over_time")
.my-6= line_chart @hours_per_category_over_time, legend: :bottom, dataset: { tension: 0.3 }

%h2= t(".activities_over_time_per_category")
.my-6.grid.grid-cols-1.gap-6{ class: "sm:grid-cols-2 lg:grid-cols-3" }
  - @hours_per_category_over_time.each do |series|
    .rounded-lg.border.border-gray-200.p-4
      .mb-2.flex.items-center.gap-2
        %span.inline-block.w-3.h-3.rounded-sm.shrink-0{ style: "background-color: #{series[:color]}" }
        %span.text-sm.font-medium= series[:name]
      = line_chart [ series ], height: "160px", legend: false, dataset: { tension: 0.3 }

