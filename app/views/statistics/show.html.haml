= content_for :title, "Statistiques"

%h1.mb-12 Statistiques

%h2 Nombre d'activités par catégorie
.my-6= column_chart @count_per_category, legend: :bottom, library: { grouped: false, scales: { x: { ticks: { display: false } } } }

.overflow-x-auto.mb-12
  %table.w-full.text-sm
    %thead
      %tr.border-b.border-gray-200.text-left.text-gray-500
        %th.py-2.pr-4.font-medium Catégorie
        %th.py-2.pr-4.font-medium.text-right Heures
        %th.py-2.font-medium.text-right Pourcentage
    %tbody
      - @top_categories.each do |row|
        %tr.border-b.border-gray-100
          %td.py-2.pr-4
            .flex.items-center.gap-2
              %span.inline-block.w-3.h-3.rounded-sm.shrink-0{ style: "background-color: #{row[:color]}" }
              = row[:label]
          %td.py-2.pr-4.text-right= row[:count]
          %td.py-2.text-right= "#{row[:percentage]}%"

%h2 Activités au cours du temps
.my-6= line_chart @hours_per_category_over_time, legend: :bottom

